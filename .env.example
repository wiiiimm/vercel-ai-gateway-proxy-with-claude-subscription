# Required — Vercel AI Gateway API key (vck_...)
PROXY_GATEWAY_KEY=

# Billing mode — how the proxy handles the caller's Authorization header
#   subscription  (default) keep caller's OAuth token; add Vercel key as
#                           x-ai-gateway-api-key. Bills to Claude Max/Pro
#                           subscription.
#   vercel                  replace Authorization with Vercel key. Bills to
#                           Vercel (or dashboard-configured BYOK if enabled).
PROXY_BILLING=subscription

# Observability tagging — both optional. Tags show up in Vercel's Custom
# Reporting; $0.075 per 1,000 unique values (negligible for stable tags).
PROXY_USER=
PROXY_TAGS=

# Server
PROXY_PORT=3456
PROXY_BIND=0.0.0.0

# Advanced
PROXY_UPSTREAM_URL=https://ai-gateway.vercel.sh
PROXY_KEY_HEADER=x-ai-gateway-api-key
PROXY_LOG_BODY=1
PROXY_LOG_HEADERS=0

# Downstream consumer env — consumed by Claude Code CLI / Agent SDK, NOT by
# this proxy. Set here so that docker-compose setups sharing this file via
# env_file also unlock fast mode for a paired claude-cli container.
#   1 (default) unlocks the /fast command in Claude Code (Opus 4.6 at ~2.5x speed,
#               billed at $30/$150 per Mtok in/out — only applies when /fast is on).
#   0           locks /fast back (Claude will reject the command on Vercel-routed
#               requests that fail the org check).
# The flag only UNLOCKS the capability — the user still has to type /fast to use it.
CLAUDE_CODE_SKIP_FAST_MODE_ORG_CHECK=1
