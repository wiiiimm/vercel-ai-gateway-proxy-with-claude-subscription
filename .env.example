# Required — Vercel AI Gateway API key (vck_...)
PROXY_GATEWAY_KEY=

# Billing mode — how the proxy handles the caller's Authorization header
#   subscription  (default) keep caller's OAuth token; add Vercel key as
#                           x-ai-gateway-api-key. Bills to Claude Max/Pro
#                           subscription.
#   vercel                  replace Authorization with Vercel key. Bills to
#                           Vercel (or dashboard-configured BYOK if enabled).
PROXY_BILLING=subscription

# Observability tagging — both optional. Tags show up in Vercel's Custom
# Reporting; $0.075 per 1,000 unique values (negligible for stable tags).
PROXY_USER=
PROXY_TAGS=

# Server
PROXY_PORT=3456
PROXY_BIND=0.0.0.0

# Advanced
PROXY_UPSTREAM_URL=https://ai-gateway.vercel.sh
PROXY_KEY_HEADER=x-ai-gateway-api-key
PROXY_LOG_BODY=1
PROXY_LOG_HEADERS=0
